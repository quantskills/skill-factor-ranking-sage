{
  "run_name": "factor_selection_sage_lgbm_smoke",
  "output_root": "../outputs/sage_lgbm_smoke",
  "random_seed": 42,
  "mode": "sage",
  "selection_count": 3,
  "input": {
    "feature_path": "toy_factors.csv",
    "label_path": "toy_labels.csv"
  },
  "data": {
    "date_col": "date",
    "ticker_col": "symbol",
    "label_col": "y"
  },
  "validation": {
    "method": "fixed",
    "train_start": 20200102,
    "train_end": 20200214,
    "valid_start": 20200217,
    "valid_end": 20200331,
    "embargo_days": 0
  },
  "model": {
    "type": "lgbm",
    "params": {
      "n_estimators": 20,
      "learning_rate": 0.05,
      "num_leaves": 7,
      "min_child_samples": 8
    }
  },
  "sage": {
    "loss": "mse",
    "background_size": 32,
    "evaluation_size": 128,
    "batch_size": 64,
    "n_permutations": 2,
    "detect_convergence": false,
    "convergence_threshold": 0.025
  }
}
